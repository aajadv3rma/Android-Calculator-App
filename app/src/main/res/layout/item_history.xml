<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/history_item_ripple"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="@dimen/history_item_padding">

    <TextView
        android:id="@+id/tvHistoryExpression"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:fontFamily="sans-serif"
        android:gravity="end"
        android:maxLines="2"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_history_expression" />

    <TextView
        android:id="@+id/tvHistoryResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="sans-serif-medium"
        android:gravity="end"
        android:textColor="@color/history_result"
        android:textSize="@dimen/text_history_result" />

    <TextView
        android:id="@+id/tvHistoryTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="sans-serif"
        android:textColor="@color/text_tertiary"
        android:textSize="11sp" />

</LinearLayout>